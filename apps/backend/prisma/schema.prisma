generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id               String                 @id @default(uuid()) @db.Uuid
  slug             String                 @unique
  legalName        String
  displayName      String
  status           String
  timezone         String
  defaultLocale    String
  createdAt        DateTime
  createdBy        String
  updatedAt        DateTime
  updatedBy        String
  deletedAt        DateTime?
  deletedBy        String?
  clinicalEvents   ClinicalHistoryEvent[]
  agendaEvents     ResidentAgendaEvent[]
  agendaSeries     ResidentAgendaSeries[]
  observationNotes ResidentObservationNote[]
  medicationExecutions MedicationExecution[]
  facilities       Facility[]
  jobTitles        JobTitle[]
  medicationOrders MedicationOrder[]
  memberships      OrganizationMembership[]
  residents        Resident[]
  roles            Role[]
  sessions         AuthSession[]

  @@index([deletedAt])
}

model Facility {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @db.Uuid
  code             String
  name             String
  status           String
  address          Json?
  phone            String?
  email            String?
  capacity         Int?
  createdAt        DateTime
  createdBy        String
  updatedAt        DateTime
  updatedBy        String
  deletedAt        DateTime?
  deletedBy        String?
  clinicalEvents   ClinicalHistoryEvent[]
  agendaEvents     ResidentAgendaEvent[]
  agendaSeries     ResidentAgendaSeries[]
  observationNotes ResidentObservationNote[]
  medicationExecutions MedicationExecution[]
  medicationOrders MedicationOrder[]
  membershipScopes MembershipFacilityScope[]
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  residents        Resident[]
  sessions         AuthSession[]
  wards            Ward[]

  @@unique([organizationId, code])
  @@index([organizationId, deletedAt])
  @@index([deletedAt])
}

/// Unidad física dentro de una residencia (ala, consultorio, piso). Se
/// referencia desde `OrganizationMembership.wardId` para marcar dónde
/// trabaja cada miembro del equipo.
model Ward {
  id               String                    @id @default(uuid()) @db.Uuid
  facilityId       String                    @db.Uuid
  code             String
  name             String
  createdAt        DateTime
  createdBy        String
  updatedAt        DateTime
  updatedBy        String
  deletedAt        DateTime?
  deletedBy        String?
  facility         Facility                  @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  memberships      OrganizationMembership[]  @relation("MembershipWard")

  @@unique([facilityId, code])
  @@index([facilityId, deletedAt])
  @@index([deletedAt])
}

model UserAccount {
  id                    String                   @id @default(uuid()) @db.Uuid
  fullName              String
  email                 String                   @unique
  password              String
  status                String                   @default("active")
  forcePasswordChange   Boolean                  @default(false)
  passwordChangedAt     DateTime?
  createdAt             DateTime
  createdBy             String
  updatedAt             DateTime
  updatedBy             String
  deletedAt             DateTime?
  deletedBy             String?
  memberships           OrganizationMembership[]
  sessions              AuthSession[]
  passwordResetsMade    PasswordResetAudit[]     @relation("PasswordResetAdmin")
  passwordResetsReceived PasswordResetAudit[]    @relation("PasswordResetTarget")

  @@index([deletedAt])
  @@map("User")
}

/// Tracks every admin-triggered password reset and every forced password change
/// completion. Source of truth for the "who reset whose password and when"
/// security audit.
model PasswordResetAudit {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  adminUserId    String?     @db.Uuid
  targetUserId   String      @db.Uuid
  action         String
  result         String
  reason         String?
  occurredAt     DateTime
  ipAddress      String?
  userAgent      String?
  admin          UserAccount? @relation("PasswordResetAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  target         UserAccount  @relation("PasswordResetTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@index([targetUserId, occurredAt])
  @@index([adminUserId, occurredAt])
}

model AuthSession {
  token                String       @id @default(uuid()) @db.Uuid
  userId               String       @db.Uuid
  activeOrganizationId String       @db.Uuid
  activeFacilityId     String?      @db.Uuid
  expiresAt            DateTime
  lastSeenAt           DateTime?
  createdAt            DateTime
  createdBy            String
  updatedAt            DateTime
  updatedBy            String
  deletedAt            DateTime?
  deletedBy            String?
  activeFacility       Facility?    @relation(fields: [activeFacilityId], references: [id], onDelete: SetNull)
  activeOrganization   Organization @relation(fields: [activeOrganizationId], references: [id], onDelete: Restrict)
  user                 UserAccount  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activeOrganizationId])
  @@index([deletedAt])
  @@map("Session")
}

model OrganizationMembership {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @db.Uuid
  userId         String                  @db.Uuid
  roleId         String                  @db.Uuid
  jobTitleId     String?                 @db.Uuid
  wardId         String?                 @db.Uuid
  shift          String?
  status         String
  isDefault      Boolean                 @default(false)
  joinedAt       DateTime
  leftAt         DateTime?
  createdAt      DateTime
  createdBy      String
  updatedAt      DateTime
  updatedBy      String
  deletedAt      DateTime?
  deletedBy      String?
  facilityScopes MembershipFacilityScope[]
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  role           Role                    @relation(fields: [roleId], references: [id], onDelete: Restrict)
  user           UserAccount             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle       JobTitle?               @relation("MembershipJobTitle", fields: [jobTitleId], references: [id], onDelete: SetNull)
  ward           Ward?                   @relation("MembershipWard", fields: [wardId], references: [id], onDelete: SetNull)
  schedules      StaffSchedule[]
  hourlyRates    MembershipHourlyRate[]
  workedHourEntries WorkedHourEntry[]
  hourSettlements HourSettlement[]

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, status])
  @@index([roleId])
  @@index([jobTitleId])
  @@index([wardId])
  @@index([deletedAt])
}

/// Historial de tarifa horaria de una membresía. La tarifa vigente es la
/// fila con `effectiveTo IS NULL` (convención: como máximo una activa por
/// membership). Los chequeos de no-solapamiento se hacen en app, no en DB,
/// porque Postgres no tiene constraint de rangos fuera de `btree_gist`.
model MembershipHourlyRate {
  id            String                 @id @default(uuid()) @db.Uuid
  membershipId  String                 @db.Uuid
  rate          Decimal                @db.Decimal(12, 2)
  currency      String
  effectiveFrom DateTime               @db.Date
  effectiveTo   DateTime?              @db.Date
  createdAt     DateTime
  createdBy     String
  updatedAt     DateTime
  updatedBy     String
  deletedAt     DateTime?
  deletedBy     String?
  membership    OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId, effectiveFrom])
  @@index([membershipId, effectiveTo])
  @@index([deletedAt])
}

/// Entrada de horas trabajadas (fase 1: sólo se cargan horas para
/// externos). Mientras `settlementId IS NULL` está en draft y es editable;
/// al liquidar se congela junto con la tarifa aplicada en `appliedRate` /
/// `appliedCurrency`, y ya no puede modificarse salvo que se cancele el
/// settlement (reverting entry a draft).
model WorkedHourEntry {
  id               String                 @id @default(uuid()) @db.Uuid
  membershipId     String                 @db.Uuid
  workDate         DateTime               @db.Date
  hours            Decimal                @db.Decimal(5, 2)
  notes            String?
  settlementId     String?                @db.Uuid
  appliedRate      Decimal?               @db.Decimal(12, 2)
  appliedCurrency  String?
  createdAt        DateTime
  createdBy        String
  updatedAt        DateTime
  updatedBy        String
  deletedAt        DateTime?
  deletedBy        String?
  membership       OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  settlement       HourSettlement?        @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@index([membershipId, workDate])
  @@index([settlementId])
  @@index([deletedAt])
}

/// Liquidación de horas para una membresía en un rango cerrado. Los
/// totales no se persisten (son `sum(entries.hours * entries.appliedRate)`
/// del set de entries con `settlementId = this.id`); se computan al vuelo
/// para respetar 3FN. Estado derivado de timestamps: `paidAt` -> paid,
/// `cancelledAt` -> cancelled, en otro caso -> issued.
model HourSettlement {
  id            String                 @id @default(uuid()) @db.Uuid
  membershipId  String                 @db.Uuid
  periodStart   DateTime               @db.Date
  periodEnd     DateTime               @db.Date
  issuedAt      DateTime
  paidAt        DateTime?
  cancelledAt   DateTime?
  notes         String?
  createdAt     DateTime
  createdBy     String
  updatedAt     DateTime
  updatedBy     String
  deletedAt     DateTime?
  deletedBy     String?
  membership    OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  entries       WorkedHourEntry[]

  @@index([membershipId, periodStart, periodEnd])
  @@index([membershipId, cancelledAt])
  @@index([deletedAt])
}

/// Catálogo de roles (permisos) por organización. 3FN: el código canónico
/// y el nombre legible viven en una única fila y se referencian desde
/// OrganizationMembership.roleId. Los cinco roles base se siembran por
/// migración al crear una organización.
model Role {
  id             String                   @id @default(uuid()) @db.Uuid
  organizationId String                   @db.Uuid
  code           String
  displayName    String
  description    String?
  createdAt      DateTime
  createdBy      String
  updatedAt      DateTime
  updatedBy      String
  deletedAt      DateTime?
  deletedBy      String?
  memberships    OrganizationMembership[]
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, code])
  @@index([organizationId, deletedAt])
  @@index([deletedAt])
}

model MembershipFacilityScope {
  id          String                 @id @default(uuid()) @db.Uuid
  membershipId String                @db.Uuid
  facilityId   String                @db.Uuid
  scopeType    String
  createdAt    DateTime
  createdBy    String
  updatedAt    DateTime
  updatedBy    String
  facility     Facility              @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  membership   OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, facilityId])
  @@index([facilityId])
}

model Resident {
  id                     String                 @id @default(uuid()) @db.Uuid
  organizationId         String                 @db.Uuid
  facilityId             String                 @db.Uuid
  firstName              String
  middleNames            String?
  lastName               String
  otherLastNames         String?
  documentType           String?
  documentNumber         String?
  documentIssuingCountry String?
  internalNumber         String?
  procedureNumber        String?
  cuil                   String?
  birthDate              DateTime
  admissionDate          DateTime
  sex                    String?
  maritalStatus          String?
  nationality            String?
  email                  String?
  room                   String
  careLevel              String
  status                 String
  careStatus             String                 @default("normal")
  careStatusChangedAt    DateTime?
  careStatusChangedBy    String?
  attachments            Json?
  insurance              Json?
  transfer               Json?
  psychiatry             Json?
  clinicalProfile        Json?
  geriatricAssessment    Json?
  belongings             Json?
  discharge              Json?
  address                Json
  emergencyContact       Json
  createdAt              DateTime
  createdBy              String
  updatedAt              DateTime
  updatedBy              String
  deletedAt              DateTime?
  deletedBy              String?
  clinicalEvents         ClinicalHistoryEvent[]
  agendaEvents           ResidentAgendaEvent[]
  agendaSeries           ResidentAgendaSeries[]
  observationNotes       ResidentObservationNote[]
  facility               Facility               @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  familyContacts         ResidentFamilyContact[]
  medicationExecutions   MedicationExecution[]
  medications            MedicationOrder[]
  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, deletedAt])
  @@index([organizationId, facilityId, deletedAt])
  @@index([deletedAt])
  @@index([organizationId, careStatus, deletedAt])
}

/// Contacto familiar del residente. Etapa 3 del backlog: expande el jsonb
/// array `Resident.familyContacts` a una relación 1:N con identidad real
/// (UUID), permitiendo búsqueda y FK desde eventos futuros.
model ResidentFamilyContact {
  id           String    @id @default(uuid()) @db.Uuid
  residentId   String    @db.Uuid
  fullName     String
  relationship String
  phone        String
  email        String?
  address      String?
  notes        String?
  createdAt    DateTime
  createdBy    String
  updatedAt    DateTime
  updatedBy    String
  deletedAt    DateTime?
  deletedBy    String?
  resident     Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@index([deletedAt])
}

/// Puesto laboral (job title) del personal: enfermería, médico, cuidador,
/// coordinador, etc. Se modela por organización para permitir que cada
/// geriátrico defina su propio catálogo. Distinto de `Role`, que modela
/// permisos de login. Se asocia al miembro del equipo vía
/// `OrganizationMembership.jobTitleId`.
model JobTitle {
  id             String                    @id @default(uuid()) @db.Uuid
  organizationId String                    @db.Uuid
  code           String
  displayName    String
  description    String?
  createdAt      DateTime
  createdBy      String
  updatedAt      DateTime
  updatedBy      String
  deletedAt      DateTime?
  deletedBy      String?
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  memberships    OrganizationMembership[]  @relation("MembershipJobTitle")

  @@unique([organizationId, code])
  @@index([organizationId, deletedAt])
  @@index([deletedAt])
}

model MedicationCatalogItem {
  id               String            @id @default(uuid()) @db.Uuid
  medicationName   String            @unique
  activeIngredient String?
  status           String
  createdAt        DateTime
  createdBy        String
  updatedAt        DateTime
  updatedBy        String
  deletedAt        DateTime?
  deletedBy        String?
  orders           MedicationOrder[]

  @@index([deletedAt])
}

model MedicationOrder {
  id                 String               @id @default(uuid()) @db.Uuid
  organizationId     String               @db.Uuid
  facilityId         String               @db.Uuid
  medicationCatalogId String              @db.Uuid
  residentId         String               @db.Uuid
  medicationName     String
  dose               String
  route              String
  frequency          String
  scheduleTimes      Json
  prescribedBy       String
  startDate          DateTime
  endDate            DateTime?
  status             String
  createdAt          DateTime
  createdBy          String
  updatedAt          DateTime
  updatedBy          String
  deletedAt          DateTime?
  deletedBy          String?
  executions         MedicationExecution[]
  facility           Facility             @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  medicationCatalog  MedicationCatalogItem @relation(fields: [medicationCatalogId], references: [id], onDelete: Restrict)
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resident           Resident             @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([organizationId, deletedAt])
  @@index([organizationId, facilityId, deletedAt])
  @@index([medicationCatalogId])
  @@index([residentId])
  @@index([deletedAt])
}

model MedicationExecution {
  id                String          @id @default(uuid()) @db.Uuid
  organizationId    String          @db.Uuid
  facilityId        String          @db.Uuid
  medicationOrderId String          @db.Uuid
  residentId        String          @db.Uuid
  medicationName    String
  result            String
  occurredAt        DateTime
  createdAt         DateTime
  createdBy         String
  updatedAt         DateTime
  updatedBy         String
  deletedAt         DateTime?
  deletedBy         String?
  facility          Facility        @relation(fields: [facilityId], references: [id], onDelete: Restrict)
  medicationOrder   MedicationOrder @relation(fields: [medicationOrderId], references: [id], onDelete: Restrict)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resident          Resident        @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([organizationId, residentId, occurredAt])
  @@index([organizationId, medicationOrderId, occurredAt])
  @@index([deletedAt])
}

/// Persistence model for the resident event timeline.
/// API and service code expose the stable ResidentEvent contract on top of it.
model ClinicalHistoryEvent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  facilityId     String?      @db.Uuid
  residentId     String       @db.Uuid
  eventType      String
  title          String
  description    String
  occurredAt     DateTime
  createdAt      DateTime
  createdBy      String
  updatedAt      DateTime
  updatedBy      String
  deletedAt      DateTime?
  deletedBy      String?
  facility       Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resident       Resident     @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([organizationId, residentId, occurredAt])
  @@index([facilityId, occurredAt])
  @@index([deletedAt])
}

/// Agenda operativa del residente: actividad puntual a futuro (medicación,
/// clase, recordatorio de turno, etc.). No modela duración ni ejecución —
/// sólo responde "qué sigue para este residente".
model ResidentAgendaEvent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  facilityId     String?      @db.Uuid
  residentId     String       @db.Uuid
  title          String
  description    String?
  scheduledAt    DateTime
  createdAt      DateTime
  createdBy      String
  updatedAt      DateTime
  updatedBy      String
  deletedAt      DateTime?
  deletedBy      String?
  facility       Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resident       Resident     @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([organizationId, scheduledAt, deletedAt])
  @@index([residentId, scheduledAt, deletedAt])
  @@index([deletedAt])
}

/// Regla de recurrencia de la agenda del residente. Cada fila expresa "este
/// evento se repite según `recurrenceType` a la hora `timeOfDay` desde
/// `startsOn` hasta `endsOn` (o indefinidamente)". Las ocurrencias concretas
/// se expanden al listar; no se materializan.
model ResidentAgendaSeries {
  id                   String                          @id @default(uuid()) @db.Uuid
  organizationId       String                          @db.Uuid
  facilityId           String?                         @db.Uuid
  residentId           String                          @db.Uuid
  title                String
  description          String?
  recurrenceType       String
  recurrenceDaysOfWeek Int[]                           @default([])
  timeOfDay            String
  startsOn             DateTime                        @db.Date
  endsOn               DateTime?                       @db.Date
  createdAt            DateTime
  createdBy            String
  updatedAt            DateTime
  updatedBy            String
  deletedAt            DateTime?
  deletedBy            String?
  facility             Facility?                       @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  organization         Organization                    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resident             Resident                        @relation(fields: [residentId], references: [id], onDelete: Restrict)
  exceptions           ResidentAgendaSeriesException[]

  @@index([organizationId, deletedAt])
  @@index([residentId, deletedAt])
  @@index([deletedAt])
}

/// Excepción puntual de una serie para una fecha específica: skip (saltear
/// la ocurrencia de ese día) u override (reemplazar título/descripción y/o
/// reprogramar a otra hora). Un único par (serie, fecha) puede tener una
/// sola excepción.
model ResidentAgendaSeriesException {
  id                   String               @id @default(uuid()) @db.Uuid
  seriesId             String               @db.Uuid
  occurrenceDate       DateTime             @db.Date
  action               String
  overrideTitle        String?
  overrideDescription  String?
  overrideScheduledAt  DateTime?
  createdAt            DateTime
  createdBy            String
  updatedAt            DateTime
  updatedBy            String
  series               ResidentAgendaSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, occurrenceDate])
  @@index([seriesId])
}

/// Horario semanal (o cobertura puntual) asociado a la membresía de un
/// usuario en una organización. Antes apuntaba a `StaffMember`; ahora el
/// usuario es la verdad y el membership ata horarios a la org activa.
model StaffSchedule {
  id            String                 @id @default(uuid()) @db.Uuid
  membershipId  String                 @db.Uuid
  weekday       Int
  startTime     String
  endTime       String
  exceptionDate DateTime?
  coverageNote  String?
  createdAt     DateTime
  createdBy     String
  updatedAt     DateTime
  updatedBy     String
  deletedAt     DateTime?
  deletedBy     String?
  membership    OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict)

  @@index([membershipId])
  @@index([exceptionDate])
  @@index([deletedAt])
}

/// Observación operativa simple del residente: nota de texto libre
/// registrada por el staff (ej. "No comió", "No salió a caminar"). Timestamp
/// automático (createdAt). Soft-delete para preservar auditoría.
model ResidentObservationNote {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  facilityId     String?      @db.Uuid
  residentId     String       @db.Uuid
  note           String
  createdAt      DateTime
  createdBy      String
  updatedAt      DateTime
  updatedBy      String
  deletedAt      DateTime?
  deletedBy      String?
  facility       Facility?    @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  resident       Resident     @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([residentId, createdAt, deletedAt])
  @@index([organizationId, deletedAt])
  @@index([deletedAt])
}
