generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  fullName  String
  email     String    @unique
  password  String
  role      String
  createdAt DateTime
  createdBy String
  updatedAt DateTime
  updatedBy String
  deletedAt DateTime?
  deletedBy String?
  sessions  Session[]

  @@index([deletedAt])
}

model Session {
  token     String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime
  createdBy String
  updatedAt DateTime
  updatedBy String
  deletedAt DateTime?
  deletedBy String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
}

model Resident {
  id               String                @id @default(uuid()) @db.Uuid
  firstName        String
  middleNames      String?
  lastName         String
  otherLastNames   String?
  documentType     String?
  documentNumber   String?
  documentIssuingCountry String?
  internalNumber   String?
  procedureNumber  String?
  cuil             String?
  birthDate        DateTime
  admissionDate    DateTime
  sex              String?
  maritalStatus    String?
  nationality      String?
  email            String?
  room             String
  careLevel        String
  status           String
  attachments      Json?
  insurance        Json?
  transfer         Json?
  psychiatry       Json?
  clinicalProfile  Json?
  belongings       Json?
  familyContacts   Json?
  discharge        Json?
  address          Json
  emergencyContact Json
  createdAt        DateTime
  createdBy        String
  updatedAt        DateTime
  updatedBy        String
  deletedAt        DateTime?
  deletedBy        String?
  medications      MedicationOrder[]
  clinicalEvents   ClinicalHistoryEvent[]

  @@index([deletedAt])
}

model StaffMember {
  id        String          @id @default(uuid()) @db.Uuid
  firstName String
  lastName  String
  role      String
  ward      String
  shift     String
  status    String
  startDate DateTime
  createdAt DateTime
  createdBy String
  updatedAt DateTime
  updatedBy String
  deletedAt DateTime?
  deletedBy String?
  schedules StaffSchedule[]

  @@index([deletedAt])
}

model MedicationCatalogItem {
  id               String            @id @default(uuid()) @db.Uuid
  medicationName   String            @unique
  activeIngredient String?
  status           String
  createdAt        DateTime
  createdBy        String
  updatedAt        DateTime
  updatedBy        String
  deletedAt        DateTime?
  deletedBy        String?
  orders           MedicationOrder[]

  @@index([deletedAt])
}

model MedicationOrder {
  id                String              @id @default(uuid()) @db.Uuid
  medicationCatalogId String            @db.Uuid
  residentId        String              @db.Uuid
  medicationName    String
  dose              String
  route             String
  frequency         String
  scheduleTimes     Json
  prescribedBy      String
  startDate         DateTime
  endDate           DateTime?
  status            String
  createdAt         DateTime
  createdBy         String
  updatedAt         DateTime
  updatedBy         String
  deletedAt         DateTime?
  deletedBy         String?
  medicationCatalog MedicationCatalogItem @relation(fields: [medicationCatalogId], references: [id], onDelete: Restrict)
  resident          Resident            @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([medicationCatalogId])
  @@index([residentId])
  @@index([deletedAt])
}

model ClinicalHistoryEvent {
  id          String    @id @default(uuid()) @db.Uuid
  residentId  String    @db.Uuid
  eventType   String
  title       String
  description String
  occurredAt  DateTime
  createdAt   DateTime
  createdBy   String
  updatedAt   DateTime
  updatedBy   String
  deletedAt   DateTime?
  deletedBy   String?
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Restrict)

  @@index([residentId, occurredAt])
  @@index([deletedAt])
}

model StaffSchedule {
  id            String      @id @default(uuid()) @db.Uuid
  staffId       String      @db.Uuid
  weekday       Int
  startTime     String
  endTime       String
  exceptionDate DateTime?
  coverageNote  String?
  createdAt     DateTime
  createdBy     String
  updatedAt     DateTime
  updatedBy     String
  deletedAt     DateTime?
  deletedBy     String?
  staffMember   StaffMember @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@index([staffId])
  @@index([exceptionDate])
  @@index([deletedAt])
}
