# --- Backend (Nest + Prisma) ---
# Conexion runtime. En Supabase: Transaction pooler (puerto 6543).
DATABASE_URL=postgresql://gentrix:gentrix@localhost:55515/gentrix?schema=public
# Conexion directa para `prisma migrate`. En Supabase: Direct/Session (puerto 5432).
# En dev local podes usar la misma que DATABASE_URL.
DIRECT_URL=postgresql://gentrix:gentrix@localhost:55515/gentrix?schema=public
PORT=3333
AUTO_SEED_DEMO=true
# CORS: vacio = reflejar cualquier origen (solo dev). En prod, lista separada
# por coma con los origenes permitidos: https://gentrix.vercel.app,https://...
CORS_ORIGIN=
# Pino level del backend. Default: 'info' en prod, 'debug' en dev.
# Valores: trace | debug | info | warn | error | fatal | silent.
LOG_LEVEL=

# --- Frontend (Vite) ---
# Vacio = usar rutas relativas y proxy de Vite (dev). En prod (Vercel), URL
# absoluta del backend en Render: https://gentrix-backend.onrender.com
VITE_API_BASE_URL=
FRONTEND_PORT=4200
FRONTEND_PREVIEW_PORT=4201
BACKEND_PORT=3333
POSTGRES_PORT=55515
GENTRIX_FRONTEND_HOST=localhost
GENTRIX_FRONTEND_PORT=4200
GENTRIX_BACKEND_PROXY_TARGET=http://localhost:3333
GENTRIX_FRONTEND_WATCH_POLLING=false
