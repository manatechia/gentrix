{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "cd apps/frontend && pnpm exec vite build",
  "outputDirectory": "dist/apps/frontend",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
